{
    "version": "2.0.7+5151",
    "description": "基于 PiliPlus 修改的 Flutter B站桌面客户端，支持离线缓存",
    "homepage": "https://github.com/Starfallan/PiliNara",
    "license": {
        "identifier": "GPL-3.0-only"
    },
    "notes": [
        "PiliNara is NOT portable. Application data is stored in standard system directories:",
        "  - Data: %APPDATA%\\com.example\\PiliNara",
        "  - Temp: Managed by Windows %TEMP%",
        "A default setting is injected during installation to prevent the app from writing logs to your Documents folder.",
        "To cleanly remove all data and settings, use 'scoop uninstall --purge pilinara'."
    ],
    "architecture": {
        "64bit": {
            "url": "https://github.com/Starfallan/PiliNara/releases/download/2.0.7.1-March7th/PiliNara_windows_2.0.7%2B5151_x64_portable.zip",
            "hash": "c6675aea80c559c855bea82e6b5ded20406238243769f056fdbcaa68aae9036f"
        }
    },
    "shortcuts": [
        [
            "pilinara.exe",
            "PiliNara"
        ]
    ],
    "post_install": [
        "Write-Host 'Injecting default setting.hive to disable logging to Documents folder...' -ForegroundColor Yellow",
        "$hiveDir = Join-Path $env:APPDATA 'com.example\\PiliNara\\hive'",
        "$settingPath = Join-Path $hiveDir 'setting.hive'",
        "if (-not (Test-Path $settingPath)) {",
        "    New-Item -ItemType Directory -Force -Path $hiveDir | Out-Null",
        "    $settingTemplate = 'FQAAAAEJZW5hYmxlTG9nAwDDP4jR'",
        "    [IO.File]::WriteAllBytes($settingPath, [Convert]::FromBase64String($settingTemplate))",
        "}"
    ],
    "post_uninstall": "if ($purge) { Remove-Item \"$env:APPDATA\\com.example\\PiliNara\", \"$env:LOCALAPPDATA\\com.example\\PiliNara\" -Force -Recurse -ErrorAction SilentlyContinue }",
    "checkver": {
        "url": "https://api.github.com/repos/Starfallan/PiliNara/releases/latest",
        "regex": "/download/(?<tag>[^/]+)/PiliNara_windows_(?<main>[\\d.]+)%2B(?<build>\\d+)_x64_portable\\.zip",
        "replace": "${main}+${build}"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/Starfallan/PiliNara/releases/download/$matchTag/PiliNara_windows_$matchMain%2B$matchBuild_x64_portable.zip"
            }
        }
    }
}
